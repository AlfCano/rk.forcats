msgid "data"
msgstr "Dados"

msgid "Factor Tools (forcats)"
msgstr "Ferramentas de Fator (forcats)"

msgid "Reorder Factor Levels by Property"
msgstr "Reordenar Níveis de Fator por Propriedade"

msgid "Reorders factor levels based on their properties, such as frequency or order of appearance."
msgstr "Reordena os níveis de fator com base em suas propriedades, como frequência ou ordem de aparecimento."

msgid "Select a factor vector from any object, choose a reordering method, and specify a name for the new factor object."
msgstr "Selecione um vetor de fator de qualquer objeto, escolha um método de reordenação e especifique um nome para o novo objeto de fator."

msgid "Factor vector to reorder"
msgstr "Vetor de fator a reordenar"

msgid "Reordering Method"
msgstr "Método de Reordenação"

msgid "By frequency"
msgstr "Por frequência"

msgid "By order of appearance"
msgstr "Por ordem de aparecimento"

msgid "By numeric value of levels"
msgstr "Pelo valor numérico dos níveis"

msgid "Reverse order"
msgstr "Ordem inversa"

msgid "Save new factor as"
msgstr "Salvar novo fator como"

msgid "Reorder Factor by Other Variables"
msgstr "Reordenar Fator por Outras Variáveis"

msgid "Factor to reorder (f)"
msgstr "Fator a reordenar (f)"

msgid "Variable to order by (.x)"
msgstr "Variável para ordenar por (.x)"

msgid "Second variable (.y, for fct_reorder2)"
msgstr "Segunda variável (.y, para fct_reorder2)"

msgid "Use two variables (fct_reorder2)"
msgstr "Usar duas variáveis (fct_reorder2)"

msgid "Reorder by Other Variable"
msgstr "Reordenar por Outra Variável"

msgid "Manually Relevel Factor"
msgstr "Renivelar Manualmente o Fator"

