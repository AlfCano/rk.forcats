msgid "Function"
msgstr "Função"

msgid "Cycle levels (fct_shift)"
msgstr "Alternar níveis (fct_shift)"

msgid "Randomly shuffle levels (fct_shuffle)"
msgstr "Misturar níveis aleatoriamente (fct_shuffle)"

msgid "Number of positions to shift (n)"
msgstr "Número de posições a deslocar (n)"

msgid "Shift or Shuffle Levels"
msgstr "Deslocar ou Misturar Níveis"

msgid "Drop Unused Factor Levels"
msgstr "Descartar Níveis de Fator Não Usados"

